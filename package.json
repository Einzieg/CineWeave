{
  "name": "cineweave",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm --filter @cineweave/web dev",
    "build": "pnpm --filter @cineweave/web build",
    "lint": "pnpm --filter @cineweave/web lint",
    "typecheck": "pnpm --filter @cineweave/web typecheck",
    "test": "pnpm run typecheck && pnpm run lint",
    "compose:infra": "docker compose --profile infra up -d",
    "compose:full": "docker compose --profile full up -d",
    "compose:down": "docker compose down --remove-orphans"
  }
}

