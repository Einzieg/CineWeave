FROM golang:1.26-alpine AS build

ARG SERVICE_PATH=workers/media-worker
WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN go build -o /out/service ./${SERVICE_PATH}

FROM alpine:3.21
RUN apk add --no-cache ca-certificates ffmpeg \
    && adduser -D -H cineweave
USER cineweave
COPY --from=build /out/service /service
ENTRYPOINT ["/service"]
